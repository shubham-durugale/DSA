class Solution(object):
    def isValid(self, s):

        stack = []

        mapping = {
            ')': '(',
            '}': '{',
            ']': '['
        }

        for ch in s:

            # opening bracket
            if ch in "({[":
                stack.append(ch)

            # closing bracket
            else:

                # stack empty OR not matching
                if not stack or stack[-1] != mapping[ch]:
                    return False

                stack.pop()

        return len(stack) == 0
