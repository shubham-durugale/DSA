class Solution(object):
    def strStr(self, haystack, needle):
        if len(needle) > len(haystack):
            return -1
        if haystack == needle:
            return 0
        if needle == haystack[:len(needle)-1]:
            return 0
        for i in range(0,(len(haystack)-len(needle))+1):
            if haystack[i:len(needle)+i] == needle:
                return i
        return -1
